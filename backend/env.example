# OpenAI credentials
# Replace this with your real API key in backend/.env.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=your_openai_base_url_here

# Model settings
# You can change these if you want to use different OpenAI models.
OPENAI_EMBEDDING_MODEL=your_embedding_model_here
OPENAI_LLM_MODEL=your_llm_model_here


#allow duplicate OpenMP libraries instead of crashing.
KMP_DUPLICATE_LIB_OK=TRUE

# Concurrency settings for different stages of the pipeline.
TRACE_STAGE3_MAX_CONCURRENCY=7
TRACE_ASSERTION_MAX_CONCURRENCY=7
TRACE_GENERATED_TESTS_MAX_CONCURRENCY=2